manifest {
	description = 'smMIPS Mutations Detection pipeline implemented using Nextflow' 
	author = 'Tuhina Srivastava'
	nextflowVersion = '20.10.0'
}

params {
	input = "${projectDir}/samplesheet.csv"
	sequences = "${projectDir}/sequences/"
	outdir = "${projectDir}/Final_Output"
	adapters = "${projectDir}/assets/TruSeq2-PE.fa"
	genome = "${projectDir}/assets/hg19_all.fasta"
	genome_dir = new File(genome).parent
	ind_files = new File(genome).name
	site1 = "${projectDir}/assets/Mills_and_1000G_gold_standard.indels.hg19.sites.vcf"
	site1_idx  = "${projectDir}/assets/Mills_and_1000G_gold_standard.indels.hg19.sites.vcf.idx"
	site2 = "${projectDir}/assets/dbsnp_138.hg19.vcf"
	site2_idx  = "${projectDir}/assets/dbsnp_138.hg19.vcf.idx"
	dbsnp_somatic = "${projectDir}/assets/dbsnp_138.hg19.somatic.vcf"
	bedfile = "${projectDir}/assets/MYOPOOL_240125_UBTF_sortd.bed"
	bedfile_exonwise = "${projectDir}/assets/MYOPOOL_231224_UBTF_exonwise_sortd.bed"
	filt3r_ref = "${projectDir}/assets/flt3_exon14-15.fa"
	filt3r = "filt3r"
	pindel_flt3 = "pindel_flt3"
	pindel_ubtf = "pindel_ubtf"
	somaticseq = "somaticseq"
	annovar_humandb = "${baseDir}/assets/humandb"
	cancervar_humandb = "${baseDir}/assets/humandb_cancervar"
	gen_ref = "${projectDir}/assets/gene_fullxref.txt"
	flt3_bedfile = "${projectDir}/assets/FLT3_pindel.bed"
	coverview_config = "${projectDir}/assets/config.txt"
	control_bam = "${projectDir}/assets/BNC2-CNVValMyOPoolV2.abra.bam"
	control_bamBai = "${projectDir}/assets/BNC2-CNVValMyOPoolV2.abra.bam.bai"
	cancervar_config = "${projectDir}/assets/config.ini"
	cancervardb = "${projectDir}/assets/cancervardb"
	artefactFile = "${projectDir}/assets/artefacts.csv"
	cava_config = "${projectDir}/assets/config_cava.txt"
	site2_zip = "${projectDir}/assets/dbsnp_138.hg19.vcf.gz"
	site2_zip_idx = "${projectDir}/assets/dbsnp_138.hg19.vcf.gz.tbi"
	ensembl_db = "${projectDir}/assets/ensembl75.gz"
	ensembl_db_index = "${projectDir}/assets/ensembl75.gz.tbi"
	cnvkitRef = "${projectDir}/assets/Reference_combpanel.cnn"
	gene_scatter_list = "${projectDir}/assets/chrwise_list.txt"
	pharma_input_xlxs = "${projectDir}/assets/For_pharmacogenomics.xlsx"
	seqinfo_rds = "${projectDir}/assets/hg19_seqinfo.rds"
	alpdb="${projectDir}/assets/ALP_ICMR.db"
	normal_wig = "${projectDir}/assets/BNC2-CNVValMyOPoolV2.tumor.wig"
}

def humandb_real = new File(params.annovar_humandb).canonicalPath
def reffile_real = new File(params.gen_ref).canonicalPath
def cancervar_humandb_real = new File(params.cancervar_humandb).canonicalPath
def cancervardb_real = new File(params.cancervardb).canonicalPath

process {

	withLabel:process_single {
		cpus   = { 1                   }
		memory = { 6.GB * task.attempt }
		time   = { 2.h  * task.attempt }
	}
	withLabel:process_low {
		cpus   = { 8     * task.attempt }
		memory = { 12.GB * task.attempt }
		time   = { 4.h   * task.attempt }
	}
	withLabel:process_inter {
		cpus   = { 16     * task.attempt }
		memory = { 32.GB * task.attempt }
		time   = { 10.h   * task.attempt }
	}
	withLabel:process_medium {
		cpus   = { 32     * task.attempt }
		memory = { 48.GB * task.attempt }
		time   = { 16.h   * task.attempt }
	}
	withLabel:process_high {
		cpus   = { 64    * task.attempt }
		memory = { 72.GB * task.attempt }
		time   = { 16.h  * task.attempt }
	}
	withLabel:process_long {
		time   = { 20.h  * task.attempt }
	}
	withLabel:process_high_memory {
		memory = { 200.GB * task.attempt }
	}


	withName:TRIM {
		container = 'quay.io/biocontainers/fastp:1.0.1--heae3180_0'
	}
	withName:/(MAPBAM|ABRA_SORT|CHR13_BAM_GEN|SUBSAMPLE|OFFTARGET_BAM_INDEX)/ {
		container = 'dukegcb/bwa-samtools:latest'
	}
	withName:/(MARK_DUPS|ALIGNMENT_METRICS|INSERT_SIZE_METRICS|ALIGNMENT_METRICS_WGS|INSERT_SIZE_METRICS_WGS|COVERAGE_WGS)/ {
		container = 'quay.io/biocontainers/picard:3.1.0--hdfd78af_0'
	}
	withName: /(BQSR|APPLY_BQSR|MUTECT2)/ {
		container = 'quay.io/biocontainers/gatk4:4.3.0.0--py36hdfd78af_0'
	}
	withName:ABRA_BAM {
		container = 'docker.io/ppawlaczek/abra:latest'
	}
	withName:/(FILT3R|GETITD)/ {
		container = 'molhemat/getitd_filt3r:1.0'
	}
	withName:FLT3_ITD_EXT {
		container = 'docker.io/zhkddocker/flt3_itd_ext:v1.1'
	}
	withName:/(COVERAGE|BAM_TO_FASTQ|OFFTARGET_BAM_GEN)/ {
		container = 'quay.io/biocontainers/bedtools:2.31.1--h13024bc_3'
	}
	withName:COVERVIEW {
		container = 'molhemat/coverview:1.0'
	}	
	withName:/(ANNOVAR|IGV_PREPROCESS)/ {
		container = 'docker.io/bioinfochrustrasbourg/annovar:2018Apr16'
		containerOptions = "-v ${humandb_real}:/databases/humandb -v ${reffile_real}:/databases/gene_fullxref.txt"
	}
	withName: /(ADDGROUPS|HSMETRICS|MUTECT2|DICT_GEN)/ {
		container = 'quay.io/biocontainers/gatk4:4.4.0.0--py36hdfd78af_0'
	}
	withName:/(FORMAT_FILT3R|PLOT_LOW_COVERAGE|FORMAT_COVERVIEW|CANCERVAR_PREPROCESS|FORMAT_PINDEL|FORMAT_SOMATICSEQ|PLOT_CNVKIT|FORMAT_ANNOTSV|FORMAT_CAVA|FORMAT_VEP_CANCERVAR|MERGE_CSV)/ {
		container = 'jupyter/scipy-notebook:x86_64-ubuntu-22.04'
	}
	withName:PLATYPUS {
		container = 'mattions/platypus:0.8.1-cwl1'
	}
	withName:FREEBAYES {
		container = 'staphb/freebayes:latest'
	}
	withName:STRELKA {
		container = 'mgibio/strelka:2.9.9'
	}
	withName:/(LOFREQ|SOMATICSEQ_CONCAT)/ {
		container = 'docker.io/kboltonlab/lofreq:1.0'
	}
	withName:VARDICT {
		container = 'quay.io/biocontainers/vardict-java:1.8.3--hdfd78af_0'
	}
	withName:DEEPSOMATIC {
		container = 'google/deepsomatic:1.6.1'
	}
	withName:SOMATICSEQ {
		container = 'lethalfang/somaticseq:latest'
	}
	withName:CANCERVAR_RUN {
		container = 'molhemat/cancervar:1.0'
		containerOptions = "-v ${cancervar_humandb_real}:/annovardb -v ${cancervardb_real}:/cancervardb"
	}
	withName:COMBINE_VARIANTS {
		container = 'broadinstitute/gatk3:3.8-1'
	}
	withName:CAVA {
		container = 'molhemat/cava_nf:1.0'
	}
	withName:/(PINDEL_FLT3|PINDEL_UBTF)/ {
		container = 'shuangbroad/pindel:v0.2.5b8'
	}
	withName:IGV_REPORTS {
		container = 'staphb/igv-reports:latest'
	}
	withName:IFCNV {
		container = 'pderouault/ifcnv:2.2.0'
	}
	withName:CNVKIT {
		container = 'etal/cnvkit:latest'
	}
	withName:ANNOTSV {
		container = 'getwilds/annotsv:latest'
	}
	withName:VEP {
		container = 'hydragenetics/vep:107'
		containerOptions = "-v ~/.vep:/.vep"
	}
	withName:/(ICHORCNA|ICHORCNA_OFFTARGET)/ {
		container = 'molhemat/ichorcna:1.3'
	}
}

executor {
	cpus   = 156
}

def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
timeline {
	enabled = true
	file    = "${params.outdir}/execution_timeline_${trace_timestamp}.html"
}
report {
	enabled = true
	file    = "${params.outdir}/execution_report_${trace_timestamp}.html"
	overwrite = true
}
trace {
	enabled = true
	file = "${params.outdir}/pipeline_trace_${trace_timestamp}.txt"
	fields = 'hash,task_id,name,status,exit,realtime,%cpu,rss'
}
dag {
	enabled = true
	file    = "${params.outdir}/pipeline_dag_${trace_timestamp}.html"
}


profiles {
	docker {
		docker.enabled          = true
		docker.runOptions       = '-u $(id -u):$(id -g)'
	}
}

workDir = '/new_disk/trash'
